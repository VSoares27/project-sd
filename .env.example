# ==============================================================================
# CERTIEVENTS - MASTER ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================
# This is a template reference file for the entire project configurations.
# Copy values from here to respective local .env files inside directories.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. LARAVEL BACKEND TEMPLATE (certievents-backend/.env)
# ------------------------------------------------------------------------------
LARAVEL_APP_NAME=CertiEvents
LARAVEL_APP_ENV=local
LARAVEL_APP_KEY=
LARAVEL_APP_DEBUG=true
LARAVEL_APP_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# 2. NESTJS BACKEND TEMPLATE (certievents-backend-nestjs/.env)
# ------------------------------------------------------------------------------
NESTJS_PORT=8001
NESTJS_MONGODB_URI=mongodb://localhost:27017/certievents

# ------------------------------------------------------------------------------
# 3. REACT FRONTEND TEMPLATE (certievents-frontend/.env)
# ------------------------------------------------------------------------------
FRONTEND_VITE_API_URL=http://localhost:8001/api

# ------------------------------------------------------------------------------
# 4. AWS SERVICES TEMPLATE (Masked for Security)
# ------------------------------------------------------------------------------
# Global AWS credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# AWS Cognito (Authentication)
COGNITO_CLIENT_ID=your_cognito_client_id

# AWS S3 (PDF Storage)
S3_BUCKET=certievents-certificados-pdf
AWS_BUCKET=certievents-certificados-pdf

# AWS SES (Email Service)
SES_FROM_EMAIL=sender@example.com
SES_FROM_NAME=CertiEvents

# AWS DynamoDB (Laravel Backend Tables)
DYNAMODB_TABLE_USUARIOS=certievents-usuarios
DYNAMODB_TABLE_CERTIFICADOS=certievents-certificados