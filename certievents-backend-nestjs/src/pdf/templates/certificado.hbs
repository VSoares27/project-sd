<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,400&display=swap" rel="stylesheet">

    <style>
        @page {
            size: A4 landscape;
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html,
        body {
            width: 297mm;
            height: 210mm;
            overflow: hidden;
            background-color: #ffffff;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 0;
        }

        /* ---------------- Container do Certificado ---------------- */
        .certificate {
            width: 297mm;
            height: 210mm;
            padding: 18mm;
            background-color: #fdfdfb; /* Papel levemente creme/off-white */
            border: 12px solid #1c3d27; /* Borda externa verde-floresta institucional */
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* ---------------- Moldura Interna Dourada ---------------- */
        .inner-border {
            width: 100%;
            height: 100%;
            border: 3px double #d4af37; /* Borda dupla dourada clássica */
            padding: 12mm 15mm;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            text-align: center;
            position: relative;
        }

        /* ---------------- Cabeçalho ---------------- */
        .header {
            margin-top: 2mm;
        }

        .header .logo-text {
            font-size: 13px;
            font-weight: 700;
            color: #1c3d27;
            letter-spacing: 2.5px;
            text-transform: uppercase;
        }

        .header .sub-logo-text {
            font-size: 10px;
            font-weight: 500;
            color: #555555;
            letter-spacing: 1.5px;
            margin-top: 4px;
            text-transform: uppercase;
        }

        /* ---------------- Título Central ---------------- */
        .title {
            margin-top: 2mm;
        }

        .title h1 {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 42px;
            font-weight: 700;
            color: #1c3d27;
            letter-spacing: 4px;
            text-transform: uppercase;
        }

        .title-divider {
            width: 80mm;
            height: 1px;
            background: linear-gradient(to right, transparent, #d4af37, transparent);
            margin: 6px auto 0 auto;
        }

        /* ---------------- Corpo de Texto ---------------- */
        .content {
            max-width: 220mm;
            margin: 4mm auto;
        }

        .content .intro {
            font-family: 'Playfair Display', Georgia, serif;
            font-style: italic;
            font-size: 16px;
            color: #555555;
            margin-bottom: 5mm;
        }

        .content .nome {
            font-size: 26px;
            font-weight: 700;
            color: #1c3d27;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin: 4mm 0;
            padding: 2px 0;
            border-bottom: 2px solid rgba(212, 175, 55, 0.3);
            display: inline-block;
        }

        .content .text {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 17px;
            color: #333333;
            line-height: 1.7;
        }

        .content .text strong {
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            color: #1c3d27;
            font-size: 16px;
        }

        /* ---------------- Assinaturas ---------------- */
        .signatures {
            display: flex;
            justify-content: space-around;
            width: 100%;
            margin-bottom: 2mm;
            padding: 0 10mm;
        }

        .signature-block {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 70mm;
        }

        .signature-line {
            width: 100%;
            border-top: 1px solid #777777;
            margin-bottom: 3px;
        }

        .signature-name {
            font-size: 11px;
            font-weight: 600;
            color: #222222;
            letter-spacing: 0.5px;
        }

        .signature-role {
            font-size: 9px;
            font-weight: 400;
            color: #666666;
            margin-top: 2px;
        }

        /* ---------------- Código de Validação / Rodapé ---------------- */
        .footer {
            width: 100%;
            display: flex;
            justify-content: flex-end;
            padding-right: 2mm;
        }

        .codigo {
            font-size: 8px;
            font-weight: 500;
            color: #888888;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
    </style>
</head>

<body>
    <div class="certificate">
        <div class="inner-border">
            <!-- Cabeçalho -->
            <div class="header">
                <div class="logo-text">Instituto Federal de Pernambuco</div>
                <div class="sub-logo-text">Campus Igarassu</div>
            </div>

            <!-- Título Principal -->
            <div class="title">
                <h1>Certificado</h1>
                <div class="title-divider"></div>
            </div>

            <!-- Texto de Certificação -->
            <div class="content">
                <p class="intro">Certificamos que</p>
                <div class="nome">{{nome}}</div>
                <p class="text">
                    participou do evento <strong>{{evento}}</strong>,<br>
                    realizado em <strong>{{data}}</strong>.
                </p>
            </div>

            <!-- Assinaturas -->
            <div class="signatures">
                <div class="signature-block">
                    <div class="signature-line"></div>
                    <div class="signature-name">Liliane Alves</div>
                    <div class="signature-role">Coordenadora do Evento</div>
                </div>
                <div class="signature-block">
                    <div class="signature-line"></div>
                    <div class="signature-name">Lincoln Tavares</div>
                    <div class="signature-role">Diretor Geral</div>
                </div>
            </div>

            <!-- Rodapé / Autenticação -->
            <div class="footer">
                <div class="codigo">Código de Autenticação: ID {{certificadoId}}</div>
            </div>
        </div>
    </div>
</body>

</html>