# ==============================================================================
# CERTIEVENTS - NESTJS BACKEND ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================

# Server Config
PORT=8000

# Database
MONGODB_URI=mongodb://localhost:27017/certievents

# AWS Global Configuration (Masked for Security)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# AWS Cognito - Authentication
COGNITO_CLIENT_ID=your_cognito_client_id

# AWS S3 - Storage
S3_BUCKET=certievents-certificados-pdf

# AWS SES - Email Service
SES_FROM_EMAIL=sender@example.com
SES_FROM_NAME=CertiEvents
