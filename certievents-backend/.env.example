# ==============================================================================
# CERTIEVENTS - LARAVEL BACKEND ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================

# Application Config
APP_NAME=CertiEvents
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Localization & Security
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (SQLite)
DB_CONNECTION=sqlite

# Session, Cache, Queue & Storage
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Memcached & Redis
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# AWS Global Configuration (Masked for Security)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# AWS S3 - Geração de PDFs (Laravel standard + Custom Service)
AWS_BUCKET=certievents-certificados-pdf
S3_BUCKET=certievents-certificados-pdf
AWS_USE_PATH_STYLE_ENDPOINT=false

# AWS Cognito - Authentication
COGNITO_CLIENT_ID=your_cognito_client_id

# AWS SES - Geração de PDFs
SES_FROM_EMAIL=sender@example.com
SES_FROM_NAME=CertiEvents

# AWS DynamoDB - Tabelas
DYNAMODB_TABLE_USUARIOS=certievents-usuarios
DYNAMODB_TABLE_CERTIFICADOS=certievents-certificados

# Laravel Mailer Configuration (SES)
MAIL_MAILER=ses
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="sender@example.com"
MAIL_FROM_NAME="CertiEvents"

# Frontend Build
VITE_APP_NAME="${APP_NAME}"
